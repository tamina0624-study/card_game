ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OPENROUTER_API_KEY が設定されている場合、AI審判はOpenRouter経由で呼び出される
# (ANTHROPIC_API_KEYより優先)。lib/claude/client.ts 参照。
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# --- MySQL(PHPブリッジ経由) ---------------------------------------------------
# DBはMySQLで、スターサーバー(public_html/card_game/php)に配置したPHPスクリプト経由でのみ
# アクセスする(lib/bridge/client.ts参照)。外部からMySQLへ直接接続はしない。
PHP_BRIDGE_URL=http://ss181301.stars.ne.jp/public_html/card_game/php
# 通常のCRUD(characters.php/decks.php/battles.php/upload.php)用の共有シークレット。
PHP_BRIDGE_API_KEY=
# migrate.php/seed.php(全データ削除を伴う破壊的操作)専用の管理者シークレット。
# PHP_BRIDGE_API_KEYとは別の値にすること(php/config.phpのADMIN_KEYと一致させる)。
PHP_BRIDGE_ADMIN_KEY=

# --- 静的アセット配信元 ---------------------------------------------------------
# backgrounds/battle-backgrounds/characters/sound/uploads は全てここから配信する
# (lib/assets.ts参照)。末尾スラッシュなし。
NEXT_PUBLIC_ASSET_BASE_URL=http://ss181301.stars.ne.jp/public_html/card_game/public
